# ─── OpenAI (asistente virtual) ─────────────────────────────────────────────
# Obtener clave: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ─── Supabase (base de datos — chat + formularios) ───────────────────────────
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Guarda: historial del asistente (chat_messages) y envíos de todos los
# formularios de contacto/visita/vender/construir (form_submissions).
# Crear tablas: ejecutá supabase/schema.sql en SQL Editor de Supabase

# ─── Sitio ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
